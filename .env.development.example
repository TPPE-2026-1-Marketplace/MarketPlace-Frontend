# DK Fashion — Frontend (Desenvolvimento)
# Copie para .env.development e ajuste os valores

# API do backend
VITE_API_URL=http://localhost:3001/api

# Credenciais para login rápido em ambiente dev
VITE_LOGIN_CLIENTE=cliente@email.com
VITE_SENHA_CLIENTE=cliente123

# Administrador criado pelo `make demo` do backend.
SELENIUM_BASE_URL=http://localhost:3000
SELENIUM_ADMIN_EMAIL=admin@demo.com
SELENIUM_ADMIN_PASSWORD=admin123
SELENIUM_PROD_ADMIN_EMAIL=
SELENIUM_PROD_ADMIN_PASSWORD=

# Gerente opcional para cenários de permissão.
SELENIUM_MANAGER_EMAIL=
SELENIUM_MANAGER_PASSWORD=
