# Docker Compose-level variables
# Usado pelo Docker Compose para interpolar ${VARIAVEIS} nos arquivos compose*.yml
# NÃO é o mesmo que .env.production / .env.development (esses são usados dentro do container)
#
# Como usar: copie este arquivo para .env e preencha os valores
# cp .env.example .env

# --- Produção ---
DOCKER_USERNAME=        # usuário no Docker Hub (ex: johndoe)
TAG=latest              # tag da imagem a ser usada (ex: v1.2.3)

# --- Porta exposta pelo compose (opcional, já tem default) ---
# APP_PORT=3000         # dev  (default: 3000)
# APP_PORT=3003         # prod (default: 3003)
